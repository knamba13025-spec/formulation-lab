---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) =>
  !data.draft && data.category === 'skincare'
);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const gradeColor: Record<string, string> = {
  A: 'bg-emerald-50 text-emerald-700 border-emerald-200',
  B: 'bg-blue-50 text-blue-700 border-blue-200',
  C: 'bg-amber-50 text-amber-700 border-amber-200',
  D: 'bg-stone-50 text-stone-500 border-stone-200',
};
---
<Layout title="スキンケア・成分解説 | Formulation Lab">
  <div class="mb-10">
    <p class="text-xs text-stone-400 uppercase tracking-widest mb-2">スキンケア</p>
    <h1 class="text-2xl font-bold mb-3">化粧品・成分解説ガイド</h1>
    <p class="text-stone-600 leading-relaxed max-w-xl">
      化粧品メーカーで処方開発に5年携わった経験から、成分表示の読み方・有効成分のエビデンス・製品の選び方を科学的に解説します。
    </p>
  </div>

  <!-- 成分早見表 -->
  <section class="mb-10 p-6 bg-white border border-stone-200 rounded-xl">
    <h2 class="text-sm font-medium text-stone-400 uppercase tracking-widest mb-4">主要アンチエイジング成分 早見表</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-stone-100">
            <th class="text-left py-2 pr-4 font-medium text-stone-600">成分</th>
            <th class="text-left py-2 pr-4 font-medium text-stone-600">効果</th>
            <th class="text-left py-2 font-medium text-stone-600">エビデンス</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-stone-50">
          {[
            { name: 'レチノール', effect: 'シワ改善・コラーゲン産生', grade: 'A' },
            { name: 'ナイアシンアミド', effect: 'シミ・毛穴・バリア機能', grade: 'A' },
            { name: 'ビタミンC誘導体', effect: 'シミ予防・抗酸化', grade: 'A' },
            { name: 'ペプチド類', effect: 'コラーゲン産生促進', grade: 'B' },
            { name: 'スピキュール', effect: '有効成分の浸透促進', grade: 'B' },
            { name: 'セラミド', effect: 'バリア機能修復', grade: 'A' },
          ].map(({ name, effect, grade }) => (
            <tr>
              <td class="py-2 pr-4 font-medium">{name}</td>
              <td class="py-2 pr-4 text-stone-600">{effect}</td>
              <td class="py-2">
                <span class={`text-xs font-medium px-2 py-0.5 border rounded ${gradeColor[grade]}`}>
                  Grade {grade}
                </span>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
  </section>

  <!-- 記事一覧 -->
  <section>
    <h2 class="text-sm font-medium text-stone-400 uppercase tracking-widest mb-4">記事一覧</h2>
    {posts.length > 0 ? (
      <div class="flex flex-col gap-4">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="p-5 bg-white border border-stone-200 rounded-xl hover:border-stone-400 transition-colors">
            <div class="flex items-center gap-2 mb-2">
              {post.data.grade && (
                <span class={`text-xs font-medium px-2 py-0.5 border rounded ${gradeColor[post.data.grade]}`}>
                  Grade {post.data.grade}
                </span>
              )}
              <span class="text-xs text-stone-400">{post.data.pubDate.toLocaleDateString('ja-JP')}</span>
            </div>
            <p class="font-medium text-stone-900">{post.data.title}</p>
            <p class="text-sm text-stone-500 mt-1">{post.data.description}</p>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-stone-400 text-sm">記事を準備中です。</p>
    )}
  </section>
</Layout>
