---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) =>
  !data.draft && data.category === 'clinic'
);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const gradeStyle: Record<string, string> = {
  A: 'background:var(--color-sage-light); color:var(--color-sage-mid); border:1px solid var(--color-sage);',
  B: 'background:var(--color-blue-light); color:var(--color-blue-mid); border:1px solid var(--color-blue);',
  C: 'background:#fef9ec; color:#b08a2a; border:1px solid #e8d48a;',
  D: 'background:#f5f2ef; color:var(--color-text-light); border:1px solid var(--color-border);',
};

const treatments = [
  {
    name: 'HIFU（ウルセラ・ウルトラフォーマー等）',
    grade: 'A',
    target: 'たるみ・リフトアップ',
    cost: '3〜15万円 / 回',
    duration: '6〜12ヶ月',
    pain: '中〜強',
    downtime: 'ほぼなし',
    note: '超音波でSMAS筋膜に作用。皮膚を切らないリフトアップとして最もエビデンスが豊富。',
    check: '機種・出力・照射数によって効果が大きく変わる。担当医の技術を重視して選ぶ。',
  },
  {
    name: 'ヒアルロン酸注射',
    grade: 'A',
    target: '法令線・目の下・頬のボリューム補填',
    cost: '2〜10万円 / 部位',
    duration: '6〜12ヶ月',
    pain: '軽〜中',
    downtime: '1〜3日（内出血の可能性）',
    note: '即効性が高く自然な仕上がりが可能。ただし技術差が結果に直結する施術。',
    check: 'ヒアルロン酸の種類・粘度が仕上がりを左右する。溶解できるクリニックを選ぶ。',
  },
  {
    name: 'ボトックス（ボツリヌストキシン）',
    grade: 'A',
    target: '表情ジワ（眉間・額・目尻）・エラ・肩こり',
    cost: '1〜5万円 / 部位',
    duration: '3〜6ヶ月',
    pain: '軽',
    downtime: 'ほぼなし',
    note: '表情ジワへの効果は高エビデンス。エラへの使用で顔のシャープ感改善も可能。',
    check: '過剰投与で表情が硬くなる。少量から試してリピートするのが賢い使い方。',
  },
  {
    name: 'レーザートーニング',
    grade: 'B',
    target: 'シミ・くすみ・毛穴',
    cost: '1〜3万円 / 回',
    duration: '3〜6ヶ月',
    pain: '軽',
    downtime: 'ほぼなし',
    note: 'メラニン産生を抑制。シミ・くすみ改善には複数回が必要。IPLと混同されがち。',
    check: '照射エネルギーが低すぎると効果なし。適切な出力設定をするクリニックを選ぶ。',
  },
  {
    name: 'フォトフェイシャル（IPL）',
    grade: 'B',
    target: '肝斑以外のシミ・赤み・毛穴',
    cost: '1〜4万円 / 回',
    duration: '3〜6ヶ月',
    pain: '軽',
    downtime: 'ほぼなし',
    note: '光の波長でシミ・血管・毛穴など複数の悩みに同時アプローチ。ダウンタイムが少ない。',
    check: '肝斑には禁忌。照射前に肌状態をしっかり診断してもらうことが必須。',
  },
  {
    name: '水光注射（スキンブースター）',
    grade: 'B',
    target: '肌のハリ・透明感・保湿力',
    cost: '3〜8万円 / 回',
    duration: '3〜6ヶ月',
    pain: '中',
    downtime: '1〜2日（針跡）',
    note: 'ヒアルロン酸・ビタミンCなどを真皮内に直接注入。肌質改善に即効性あり。',
    check: '使用する薬剤の種類・クオリティがクリニックによって異なる。成分を事前確認。',
  },
  {
    name: '幹細胞治療・PRP療法',
    grade: 'C',
    target: '肌再生・若返り（研究段階）',
    cost: '30〜100万円',
    duration: '不明（個人差が大きい）',
    pain: '中',
    downtime: '施術により異なる',
    note: 'エビデンスはまだ限定的。効果の個人差が非常に大きい。費用対効果の検証が不十分。',
    check: '高額施術は第三者機関のエビデンスを必ず確認。「再生医療等の安全性の確保等に関する法律」の認定施設かを確認する。',
  },
];
---
<Layout title="美容医療・施術ガイド | エイジングケアラボ" description="HIFU・PDRN・ヒアルロン酸注入など美容医療施術の効果・費用・リスクを症例数や医師選びの視点で比較するガイド。">

  <!-- ページヘッダー -->
  <section style="padding: 2.5rem 0 2rem; border-bottom: 1px solid var(--color-border);">
    <p style="font-size:0.7rem; letter-spacing:0.2em; color:var(--color-blue-mid); text-transform:uppercase; margin-bottom:0.75rem;">Clinic</p>
    <h1 style="font-family:'Cormorant Garamond',serif; font-size:2rem; font-weight:300; color:var(--color-text); margin-bottom:0.75rem;">
      美容医療・施術ガイド
    </h1>
    <p style="font-size:0.875rem; color:var(--color-text-muted); line-height:1.9; max-width:32rem;">
      HIFU・ヒアルロン酸・ボトックスなど主要施術の効果・費用・ダウンタイムを比較します。クリニック選びで結果が変わる施術も多い。「何を受けるか」より「どこで受けるか」も重要です。
    </p>
  </section>

  <!-- 選び方のポイント -->
  <section style="margin: 2rem 0; padding: 1.25rem 1.5rem; background:var(--color-blue-light); border-left:3px solid var(--color-blue); border-radius:0 8px 8px 0;">
    <p style="font-size:0.75rem; color:var(--color-blue-mid); font-weight:500; margin-bottom:0.4rem;">美容医療を選ぶ前に確認すること</p>
    <div style="font-size:0.82rem; color:#2a4a5c; line-height:1.9;">
      <p>① 自分の悩みが「たるみ」「シミ」「ボリューム不足」「ハリ低下」のどれかを明確にする</p>
      <p>② 医師の症例数・専門領域を確認する（特にヒアルロン酸・HIFU）</p>
      <p>③ カウンセリングで断れるかどうかを確認してから予約する</p>
    </div>
  </section>

  <!-- 施術比較テーブル -->
  <section style="margin-bottom:2.5rem;">
    <p style="font-size:0.7rem; letter-spacing:0.15em; color:var(--color-text-light); text-transform:uppercase; margin-bottom:1.25rem;">主要施術 詳細比較</p>
    <div style="display:flex; flex-direction:column; gap:1rem;">
      {treatments.map(({ name, grade, target, cost, duration, pain, downtime, note, check }) => (
        <div style="padding:1.25rem; background:var(--color-surface); border:1px solid var(--color-border); border-radius:10px;">
          <div style="display:flex; align-items:flex-start; gap:0.75rem; margin-bottom:0.75rem;">
            <span style={`font-size:0.62rem; font-weight:500; padding:0.2rem 0.5rem; border-radius:4px; flex-shrink:0; margin-top:0.15rem; ${gradeStyle[grade]}`}>
              Grade {grade}
            </span>
            <div>
              <p style="font-size:0.95rem; font-weight:500; color:var(--color-text); margin-bottom:0.3rem;">{name}</p>
              <span style="font-size:0.7rem; color:var(--color-blue-mid); background:var(--color-blue-light); padding:0.1rem 0.5rem; border-radius:3px;">{target}</span>
            </div>
          </div>

          <!-- スペック -->
          <div style="display:grid; grid-template-columns:repeat(4,1fr); gap:0.5rem; margin-bottom:0.75rem; padding:0.75rem; background:var(--color-bg); border-radius:6px;">
            {[
              { label: '費用目安', val: cost },
              { label: '持続期間', val: duration },
              { label: '痛み', val: pain },
              { label: 'ダウンタイム', val: downtime },
            ].map(({ label, val }) => (
              <div>
                <p style="font-size:0.62rem; color:var(--color-text-light); margin-bottom:0.15rem;">{label}</p>
                <p style="font-size:0.75rem; color:var(--color-text); font-weight:500;">{val}</p>
              </div>
            ))}
          </div>

          <div style="display:flex; flex-direction:column; gap:0.35rem; border-left:2px solid var(--color-border); padding-left:1rem;">
            <p style="font-size:0.78rem; color:var(--color-text-muted);">{note}</p>
            <p style="font-size:0.75rem; color:var(--color-blue-mid);"><strong style="font-weight:500;">選ぶ際のポイント：</strong>{check}</p>
          </div>
        </div>
      ))}
    </div>
    <p style="font-size:0.72rem; color:var(--color-text-light); margin-top:1rem; text-align:right;">※ 価格はクリニックにより異なります。カウンセリングで確認してください。</p>
  </section>

  <!-- 記事一覧 -->
  <section>
    <p style="font-size:0.7rem; letter-spacing:0.15em; color:var(--color-text-light); text-transform:uppercase; margin-bottom:1.25rem;">関連記事</p>
    {posts.length > 0 ? (
      <div style="display:flex; flex-direction:column; gap:0.75rem;">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} style="display:flex; align-items:flex-start; gap:1rem; padding:1rem 1.25rem; background:var(--color-surface); border:1px solid var(--color-border); border-radius:10px; text-decoration:none; transition:border-color 0.2s;"
             onmouseover="this.style.borderColor='var(--color-blue)'" onmouseout="this.style.borderColor='var(--color-border)'">
            <div style="flex:1;">
              <p style="font-size:0.875rem; color:var(--color-text); margin-bottom:0.25rem;">{post.data.title}</p>
              <p style="font-size:0.775rem; color:var(--color-text-muted);">{post.data.description}</p>
            </div>
            <span style="color:var(--color-text-light); font-size:0.8rem; flex-shrink:0;">→</span>
          </a>
        ))}
      </div>
    ) : (
      <p style="font-size:0.85rem; color:var(--color-text-light);">記事を準備中です。</p>
    )}
  </section>

</Layout>
