---
import Layout from '../../layouts/Layout.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) =>
  !data.draft && data.category === 'supplement'
);
posts.sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());

const gradeColor: Record<string, string> = {
  A: 'bg-emerald-50 text-emerald-700 border-emerald-200',
  B: 'bg-blue-50 text-blue-700 border-blue-200',
  C: 'bg-amber-50 text-amber-700 border-amber-200',
  D: 'bg-stone-50 text-stone-500 border-stone-200',
};
---
<Layout title="サプリメント・機能性食品 | Formulation Lab">
  <div class="mb-10">
    <p class="text-xs text-stone-400 uppercase tracking-widest mb-2">サプリメント</p>
    <h1 class="text-2xl font-bold mb-3">機能性食品・サプリガイド</h1>
    <p class="text-stone-600 leading-relaxed max-w-xl">
      NMN・GLP-1・セノリティクスなど、最新のアンチエイジングサプリを臨床試験フェーズ・国内入手可否も含めて解説します。
    </p>
  </div>

  <!-- 注目サプリ早見表 -->
  <section class="mb-10 p-6 bg-white border border-stone-200 rounded-xl">
    <h2 class="text-sm font-medium text-stone-400 uppercase tracking-widest mb-4">注目成分 現状まとめ（2026年）</h2>
    <div class="flex flex-col gap-3">
      {[
        { name: 'NMN', status: '国内販売あり', phase: '臨床試験 Phase 2', grade: 'B', note: 'NAD+前駆体。ミトコンドリア機能維持' },
        { name: 'ラパマイシン', status: '医師処方のみ', phase: '長寿研究で注目', grade: 'B', note: 'mTOR阻害薬。動物実験で寿命延長実証済み' },
        { name: 'セノリティクス（D+Q）', status: '個人輸入', phase: '臨床試験 Phase 2-3', grade: 'B', note: 'ダサチニブ+ケルセチン。老化細胞除去' },
        { name: 'レスベラトロール', status: '国内販売あり', phase: 'サプリ', grade: 'C', note: 'SIRT1活性化。ヒト試験では効果不明確' },
        { name: 'スペルミジン', status: '国内販売あり', phase: '臨床試験 Phase 2', grade: 'C', note: 'オートファジー誘導。研究進行中' },
      ].map(({ name, status, phase, grade, note }) => (
        <div class="flex items-start gap-3 py-3 border-b border-stone-50 last:border-0">
          <span class={`text-xs font-medium px-2 py-0.5 border rounded mt-0.5 flex-shrink-0 ${gradeColor[grade]}`}>
            Grade {grade}
          </span>
          <div>
            <div class="flex items-center gap-2">
              <span class="font-medium text-sm">{name}</span>
              <span class="text-xs text-stone-400">{status}</span>
              <span class="text-xs text-stone-400">/ {phase}</span>
            </div>
            <p class="text-xs text-stone-500 mt-0.5">{note}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- 記事一覧 -->
  <section>
    <h2 class="text-sm font-medium text-stone-400 uppercase tracking-widest mb-4">記事一覧</h2>
    {posts.length > 0 ? (
      <div class="flex flex-col gap-4">
        {posts.map(post => (
          <a href={`/blog/${post.id}`} class="p-5 bg-white border border-stone-200 rounded-xl hover:border-stone-400 transition-colors">
            <div class="flex items-center gap-2 mb-2">
              {post.data.grade && (
                <span class={`text-xs font-medium px-2 py-0.5 border rounded ${gradeColor[post.data.grade]}`}>
                  Grade {post.data.grade}
                </span>
              )}
              <span class="text-xs text-stone-400">{post.data.pubDate.toLocaleDateString('ja-JP')}</span>
            </div>
            <p class="font-medium">{post.data.title}</p>
            <p class="text-sm text-stone-500 mt-1">{post.data.description}</p>
          </a>
        ))}
      </div>
    ) : (
      <p class="text-stone-400 text-sm">記事を準備中です。</p>
    )}
  </section>
</Layout>
